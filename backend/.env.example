# ─── Application ──────────────────────────────────────────────
APP_NAME=Strikfin
APP_ENV=development
DEBUG=true

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:portnumber

# ─── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── PostgreSQL Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=StrikfinDB
DB_USER=postgres
DB_PASSWORD=YourStrongPassword123!

# ─── Market Data ──────────────────────────────────────────────
MARKET_DATA_VENDOR=mock

# ─── LLM (optional) ───────────────────────────────────────────
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
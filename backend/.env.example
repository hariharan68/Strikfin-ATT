# ─── Application ──────────────────────────────────────────────
APP_NAME=Strikfin
APP_ENV=development
DEBUG=true

# ─── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── MSSQL Database ───────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=StrikfinDB
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!
DB_DRIVER=ODBC Driver 17 for SQL Server

# ─── Market Data ──────────────────────────────────────────────
MARKET_DATA_VENDOR=mock

# ─── LLM (optional) ───────────────────────────────────────────
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173